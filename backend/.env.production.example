# Production environment variables for the backend. Copy to backend/.env or set these values in cPanel.
NODE_ENV=production
PORT=
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
TRUST_PROXY=1
ALLOW_ADMIN_BOOTSTRAP=false
ALLOW_IMAGE_REMOVAL=false
ALLOW_DESTRUCTIVE_SEED=false
SKIP_DB_GATE=false
ENABLE_TEST_LOGS=false
COOKIE_SECURE=true
ADMIN_SESSION_IDLE_TIMEOUT_MS=1800000
ADMIN_SESSION_ABSOLUTE_TIMEOUT=8h

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/<database>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_secure_32+_character_secret
JWT_EXPIRE=7d

# Frontend URLs and CORS
FRONTEND_URL=https://your-domain.com
CLIENT_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com
PASSWORD_RESET_URL=https://your-domain.com/#/admin/reset-password
EMAIL_VERIFICATION_URL=https://your-domain.com/#/admin/verify-email

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CLEANUP_INTERVAL_MS=3600000
STRIPE_CLEANUP_ORDER_AGE_MS=7200000

# Email / SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM="JTS Beauty <no-reply@your-domain.com>"
SMTP_FROM="JTS Beauty <no-reply@your-domain.com>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional third-party secrets
TURNSTILE_SECRET_KEY=
