# Frontend Production Environment Configuration

# Production API URL
# Points to the production backend at api.jtsbeautyllc.com
VITE_API_URL=https://api.jtsbeautyllc.com/api

# API request timeout in milliseconds
VITE_API_TIMEOUT_MS=10000

# Environment Mode (detected by Vite automatically, but can be overridden)
# Must be: production
NODE_ENV=production
