# Environment Variables - Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=100
ALLOW_ADMIN_BOOTSTRAP=false

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://jtsbeautyllc.com
CLIENT_URL=https://jtsbeautyllc.com

# Stripe
STRIPE_SECRET_KEY=REDACTED_FOR_PRODUCTION
STRIPE_WEBHOOK_SECRET=REDACTED_FOR_PRODUCTION

# Password reset email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="JTS Beauty <no-reply@jtsbeauty.com>"
SMTP_FROM="JTS Beauty <no-reply@jtsbeauty.com>"
PASSWORD_RESET_URL=https://jtsbeautyllc.com/#/admin/reset-password
EMAIL_VERIFICATION_URL=https://jtsbeautyllc.com/#/admin/verify-email

# Admin 2FA
TWO_FACTOR_ISSUER=JTS Beauty
TWO_FACTOR_ENCRYPTION_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
